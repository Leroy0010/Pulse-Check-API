# syntax=docker/dockerfile:1.7

FROM eclipse-temurin:25-jdk-jammy AS builder

WORKDIR /app

COPY mvnw .
COPY .mvn .mvn
COPY pom.xml .

RUN chmod +x mvnw

RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw dependency:go-offline dependency:resolve-plugins -B

COPY src src

RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw clean package -DskipTests

# FIXED: Explicitly set the destination directory to 'extracted'
RUN java -Djarmode=tools -jar target/*.jar extract --layers --launcher --destination extracted

# --- Final Stage ---
FROM gcr.io/distroless/java25-debian13:nonroot

WORKDIR /app

# FIXED: Safely copy from the explicit /app/extracted/ destination layout
COPY --from=builder /app/extracted/dependencies/ ./
COPY --from=builder /app/extracted/spring-boot-loader/ ./
COPY --from=builder /app/extracted/snapshot-dependencies/ ./
COPY --from=builder /app/extracted/application/ ./

ENTRYPOINT ["java", "org.springframework.boot.loader.launch.JarLauncher", "--spring.profiles.active=prod"]
